---
const STEPS = [
  {
    n: '01',
    name: 'Plan',
    optional: true,
    desc: 'Generate prd.json from a spec file using an LLM. Stories are decomposed, sized, and sequenced automatically.',
  },
  {
    n: '02',
    name: 'Acceptance setup',
    desc: 'Generate acceptance tests and assert RED before implementation begins. No green tests allowed at this stage.',
  },
  {
    n: '03',
    name: 'Route',
    desc: 'Classify story complexity and select a model tier — fast, balanced, or powerful. Security-critical stories always escalate.',
  },
  {
    n: '04',
    name: 'Execute',
    desc: 'Run the agent session. Claude Code, Codex, Gemini CLI, or any ACP-compatible agent. Context and constitution are injected per story.',
  },
  {
    n: '05',
    name: 'Verify',
    desc: 'Run scoped tests. On failure, the rectification loop fires first — fixing before escalating to the next model tier.',
  },
  {
    n: '06',
    name: 'Review',
    desc: 'Lint, typecheck, semantic review against ACs, and adversarial review for edge cases. Autofix runs before escalation.',
  },
  {
    n: '07',
    name: 'Escalate & loop',
    desc: 'On repeated failure, retry with a higher model tier. Repeat until all stories pass or cost / iteration limits are hit.',
  },
  {
    n: '08',
    name: 'Regression gate',
    desc: 'Full test suite runs once after all stories complete. nax retries failed suites; a gate failure does not block the feature.',
  },
  {
    n: '09',
    name: 'Acceptance',
    desc: 'Run the original acceptance tests against the finished feature. GREEN here means done.',
  },
];
---

<section class="py-24 px-6 border-t border-[#111]">
  <div class="max-w-[900px] mx-auto">
    <!-- Header -->
    <div class="mb-12 reveal">
      <p class="font-mono text-[11px] text-[#444] tracking-widest uppercase mb-3">How it works</p>
      <h2 class="font-sans font-bold text-[32px] leading-tight tracking-[-0.02em] text-white">
        A loop with teeth.
      </h2>
    </div>

    <!-- Steps -->
    <div class="relative stagger">
      <!-- Vertical line -->
      <div class="absolute left-[27px] top-4 bottom-4 w-px bg-[#1a1a1a] hidden sm:block"></div>

      <div class="flex flex-col gap-0">
        {STEPS.map((step, i) => (
          <div class="relative flex gap-6 group">
            <!-- Step number -->
            <div class="relative z-10 flex-shrink-0 w-14 h-14 flex items-center justify-center">
              <div class="w-8 h-8 rounded-full border border-[#222] bg-[#000] flex items-center justify-center group-hover:border-[#333] transition-colors">
                <span class="font-mono text-[10px] text-[#444] group-hover:text-[#666] transition-colors">{step.n}</span>
              </div>
            </div>

            <!-- Content -->
            <div class={`flex-1 pb-8 ${i === STEPS.length - 1 ? 'pb-0' : ''}`}>
              <div class="flex items-center gap-2 mb-1 pt-3">
                <h3 class="font-semibold text-[14px] text-white tracking-tight">{step.name}</h3>
                {step.optional && (
                  <span class="font-mono text-[10px] text-[#333] border border-[#1f1f1f] rounded px-1.5 py-0.5">optional</span>
                )}
              </div>
              <p class="text-[13px] text-[#666] leading-[1.65] max-w-[540px]">{step.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>

---
const QUICKSTART = `cd your-project
nax init                           # Create .nax/ structure
nax features create my-feature     # Scaffold a feature

# Write your spec, then run
nax run -f my-feature --plan --from spec.md`;
---

<section class="py-24 px-6 border-t border-[#111]">
  <div class="max-w-[900px] mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-12 items-start">
      <!-- Left: Install -->
      <div class="reveal">
        <p class="font-mono text-[11px] text-[#444] tracking-widest uppercase mb-4">Install</p>
        <p class="text-[15px] text-[#666] mb-6 leading-relaxed">
          Requires Bun 1.3.7+ or Node 22+.<br />Git must be initialized in your project.
        </p>

        <!-- npm -->
        <div class="mb-3">
          <p class="font-mono text-[10px] text-[#333] uppercase tracking-widest mb-2">npm</p>
          <div class="flex items-center gap-2 px-4 py-3 rounded-lg bg-[#0a0a0a] border border-[#1a1a1a]">
            <span class="font-mono text-[13px] text-[#777]">$</span>
            <span class="font-mono text-[13px] text-[#bbb]">npm install -g @nathapp/nax</span>
          </div>
        </div>

        <!-- bun -->
        <div>
          <p class="font-mono text-[10px] text-[#333] uppercase tracking-widest mb-2">bun</p>
          <div class="flex items-center gap-2 px-4 py-3 rounded-lg bg-[#0a0a0a] border border-[#1a1a1a]">
            <span class="font-mono text-[13px] text-[#777]">$</span>
            <span class="font-mono text-[13px] text-[#bbb]">bun install -g @nathapp/nax</span>
          </div>
        </div>
      </div>

      <!-- Right: Quick start -->
      <div class="reveal">
        <p class="font-mono text-[11px] text-[#444] tracking-widest uppercase mb-4">Quick start</p>
        <div class="rounded-lg bg-[#0a0a0a] border border-[#1a1a1a] overflow-hidden">
          <!-- Terminal header -->
          <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-[#141414]">
            <span class="w-2.5 h-2.5 rounded-full bg-[#222]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#222]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#222]"></span>
          </div>
          <!-- Code -->
          <pre class="px-5 py-4 font-mono text-[12px] leading-[1.8] text-[#bbb] overflow-x-auto whitespace-pre"><code>{QUICKSTART}</code></pre>
        </div>

        <p class="mt-4 text-[12px] text-[#444] leading-relaxed">
          Or skip interactive planning with{' '}
          <code class="font-mono text-[11px] text-[#555] bg-[#0f0f0f] border border-[#1a1a1a] px-1.5 py-0.5 rounded">--plan --from spec.md</code>
          {' '}for a single-command run.
        </p>
      </div>
    </div>
  </div>
</section>

---
const QUICKSTART = `cd your-project
nax init                           # Create .nax/ structure
nax features create my-feature     # Scaffold a feature

# Write your spec, then run
nax run -f my-feature --plan --from spec.md`;
---

<section class="py-24 px-6 border-t border-[#eee]">
  <div class="max-w-[900px] mx-auto">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-12 items-start">
      <!-- Left: Install -->
      <div class="reveal">
        <div class="flex items-center gap-3 mb-4">
          <p class="font-mono text-[11px] text-[#bbb] tracking-widest uppercase">Install</p>
          <a
            id="nax-version-badge"
            href="https://github.com/nathapp-io/nax/releases"
            target="_blank"
            rel="noopener noreferrer"
            class="hidden font-mono text-[10px] text-[#aaa] bg-[#f5f5f5] border border-[#e5e5e5] px-2 py-0.5 rounded hover:border-[#ccc] transition-colors"
          ></a>
        </div>
        <p class="text-[15px] text-[#999] mb-6 leading-relaxed">
          Requires Bun 1.3.7+ or Node 22+.<br />Git must be initialized in your project.
        </p>

        <!-- npm -->
        <div class="mb-3">
          <p class="font-mono text-[10px] text-[#ccc] uppercase tracking-widest mb-2">npm</p>
          <div class="flex items-center gap-2 px-4 py-3 rounded-lg bg-[#f5f5f5] border border-[#e5e5e5]">
            <span class="font-mono text-[13px] text-[#888]">$</span>
            <span class="font-mono text-[13px] text-[#444]">npm install -g @nathapp/nax</span>
          </div>
        </div>

        <!-- bun -->
        <div>
          <p class="font-mono text-[10px] text-[#ccc] uppercase tracking-widest mb-2">bun</p>
          <div class="flex items-center gap-2 px-4 py-3 rounded-lg bg-[#f5f5f5] border border-[#e5e5e5]">
            <span class="font-mono text-[13px] text-[#888]">$</span>
            <span class="font-mono text-[13px] text-[#444]">bun install -g @nathapp/nax</span>
          </div>
        </div>
      </div>

      <!-- Right: Quick start -->
      <div class="reveal">
        <p class="font-mono text-[11px] text-[#bbb] tracking-widest uppercase mb-4">Quick start</p>
        <div class="rounded-lg bg-[#f5f5f5] border border-[#e5e5e5] overflow-hidden">
          <!-- Terminal header -->
          <div class="flex items-center gap-1.5 px-4 py-2.5 border-b border-[#ebebeb]">
            <span class="w-2.5 h-2.5 rounded-full bg-[#ddd]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#ddd]"></span>
            <span class="w-2.5 h-2.5 rounded-full bg-[#ddd]"></span>
          </div>
          <!-- Code -->
          <pre class="px-5 py-4 font-mono text-[12px] leading-[1.8] text-[#444] overflow-x-auto whitespace-pre"><code>{QUICKSTART}</code></pre>
        </div>

        <p class="mt-4 text-[12px] text-[#bbb] leading-relaxed">
          Or skip interactive planning with{' '}
          <code class="font-mono text-[11px] text-[#aaa] bg-[#f0f0f0] border border-[#e5e5e5] px-1.5 py-0.5 rounded">--plan --from spec.md</code>
          {' '}for a single-command run.
        </p>
      </div>
    </div>
  </div>
</section>

<script>
  const CACHE_KEY = 'nax-version-cache';
  const CACHE_TTL = 60 * 60 * 1000; // 1 hour (mirrors server-side cache)

  function getCached(): string | null {
    try {
      const raw = localStorage.getItem(CACHE_KEY);
      if (!raw) return null;
      const { version, ts } = JSON.parse(raw) as { version: string; ts: number };
      return Date.now() - ts < CACHE_TTL ? version : null;
    } catch {
      return null;
    }
  }

  function setCached(version: string): void {
    try {
      localStorage.setItem(CACHE_KEY, JSON.stringify({ version, ts: Date.now() }));
    } catch { /* ignore quota errors */ }
  }

  function renderVersion(version: string): void {
    const badge = document.getElementById('nax-version-badge');
    if (!badge) return;
    badge.textContent = version;
    badge.classList.remove('hidden');
  }

  async function loadVersion(): Promise<void> {
    const cached = getCached();
    if (cached) {
      renderVersion(cached);
      return;
    }

    try {
      const res = await fetch('/api/version');
      if (!res.ok) throw new Error(`HTTP ${res.status}`);
      const { version } = await res.json() as { version: string | null };
      if (version) {
        setCached(version);
        renderVersion(version);
      }
    } catch {
      // Non-critical — badge stays hidden if all else fails
    }
  }

  loadVersion();
</script>
